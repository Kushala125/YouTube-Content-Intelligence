      <aliases enabled='yes' />
      <column caption='Publish Hour' datatype='integer' name='[Calculation_2753228812451842]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEPART(&apos;hour&apos;, [publish_time])' />
      </column>
      <column caption='Publish Day' datatype='string' name='[Calculation_2753228812673027]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATENAME(&apos;weekday&apos;, [publish_time])' />
      </column>
      <column caption='Like Comment Ratio' datatype='real' name='[Calculation_2753228812779524]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[likes] / [comments]' />
      </column>
      <column caption='High Engagement' datatype='boolean' name='[Calculation_2753228813205511]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_2753228812779524] &gt; 20 THEN TRUE ELSE FALSE END' />
        <aliases>
          <alias key='false' value='Low Engagment' />
          <alias key='true' value='high engagment' />
        </aliases>
      </column>
      <column caption='Channel Average Views' datatype='real' name='[Calculation_2753228813459464]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [channel_title] : AVG([views]) }' />
      </column>
      <column caption='Category Average Views' datatype='real' name='[Calculation_2753228813565961]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [category_id] : AVG([views]) }' />
      </column>
      <column caption='Engagement Rate' datatype='real' name='[Calculation_2753228813864970]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[likes] / [views]' />
      </column>
      <column caption='Views vs Channel Performance' datatype='real' name='[Calculation_2753228813967371]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[views] / [Calculation_2753228813459464]' />
      </column>
      <column caption='Day Order' datatype='integer' name='[Calculation_2753228942229517]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Calculation_2753228812673027]&#10;WHEN &quot;Monday&quot; THEN 1&#10;WHEN &quot;Tuesday&quot; THEN 2&#10;WHEN &quot;Wednesday&quot; THEN 3&#10;WHEN &quot;Thursday&quot; THEN 4&#10;WHEN &quot;Friday&quot; THEN 5&#10;WHEN &quot;Saturday&quot; THEN 6&#10;WHEN &quot;Sunday&quot; THEN 7&#10;END' />
      </column>
      <column caption='Performance Score' datatype='real' name='[Calculation_2753228961386511]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[views] / [Calculation_2753228813459464]' />
      </column>
      <column caption='Engagement Score' datatype='real' name='[Calculation_2753228981186577]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([likes] * 0.7 + [comments] * 0.3) / [views]' />
      </column>
      <column caption=' Performance Score' datatype='real' name='[Calculation_2753228981354514]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[views] / [Calculation_2753228813459464]' />
      </column>
      <column caption='Normalized Views' datatype='real' name='[Calculation_2753228987453461]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[views] / { FIXED : MAX([views]) }' />
      </column>
      <column caption='Normalized Likes' datatype='real' name='[Calculation_2753228987772950]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[likes] / { FIXED : MAX([likes]) }' />
      </column>
      <column caption='Normalized Comments' datatype='real' name='[Calculation_2753228987858967]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[comments] / { FIXED : MAX([comments]) }' />
      </column>
      <column caption='Channel Strength' datatype='real' name='[Calculation_2753228988555288]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_2753228813459464] / { FIXED : AVG([views]) }' />
      </column>
      <column caption='Comment Intensity' datatype='real' name='[Calculation_2753228989173785]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[comments] / ([likes] + 1)' />
      </column>
      <column caption='Overperformance Score' datatype='real' name='[Calculation_2753228989267994]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([views] - [Calculation_2753228813459464]) / [Calculation_2753228813459464]' />
      </column>
      <column caption='Engagement Efficiency' datatype='real' name='[Calculation_2753228989435931]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([likes] + [comments]) / [views]' />
      </column>
      <column caption='Velocity' datatype='real' name='[Calculation_2753228990267420]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[views] / DATEDIFF(&apos;hour&apos;, [publish_time], NOW())' />
      </column>

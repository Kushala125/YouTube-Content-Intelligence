          <datasource-dependencies datasource='federated.0fkxawy17iy9o01d92id51t7xwqk'>
            <column caption='Publish Hour' datatype='integer' name='[Calculation_2753228812451842]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='DATEPART(&apos;hour&apos;, [publish_time])' />
            </column>
            <column caption='Like Comment Ratio' datatype='real' name='[Calculation_2753228812779524]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[likes] / [comments]' />
            </column>
            <column caption='Channel Average Views' datatype='real' name='[Calculation_2753228813459464]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [channel_title] : AVG([views]) }' />
            </column>
            <column caption='Performance Score' datatype='real' name='[Calculation_2753228961386511]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[views] / [Calculation_2753228813459464]' />
            </column>
            <column caption=' Performance Score' datatype='real' name='[Calculation_2753228981354514]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[views] / [Calculation_2753228813459464]' />
            </column>
            <column caption='Channel Strength' datatype='real' name='[Calculation_2753228988555288]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_2753228813459464] / { FIXED : AVG([views]) }' />
            </column>
            <column caption='Engagement Efficiency' datatype='real' name='[Calculation_2753228989435931]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='([likes] + [comments]) / [views]' />
            </column>
            <column caption='Velocity' datatype='real' name='[Calculation_2753228990267420]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[views] / DATEDIFF(&apos;hour&apos;, [publish_time], NOW())' />
            </column>
